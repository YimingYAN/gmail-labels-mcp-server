{
  "name": "gmail-labels-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Gmail label management with auto-refreshing OAuth2",
  "main": "dist/index.js",
  "bin": {
    "gmail-labels-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "auth": "GOOGLE_CLIENT_ID=$GOOGLE_CLIENT_ID GOOGLE_CLIENT_SECRET=$GOOGLE_CLIENT_SECRET tsx scripts/auth.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["mcp", "gmail", "labels", "model-context-protocol", "claude", "ai"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YimingYAN/gmail-labels-mcp-server.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.0",
    "google-auth-library": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
